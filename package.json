{
  "name": "@sonanlee/clackbot",
  "version": "3.0.0",
  "description": "개인 로컬 Slack 비서 — Claude Code 기반 Slack 에이전트",
  "type": "module",
  "bin": {
    "clackbot": "./dist/bin/clackbot.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc && vite build && node scripts/copy-assets.cjs",
    "dev:frontend": "vite",
    "build:frontend": "vite build",
    "start": "node dist/bin/clackbot.js start",
    "test": "vitest"
  },
  "keywords": [
    "slack",
    "bot",
    "claude",
    "agent",
    "assistant"
  ],
  "author": "sonanlee",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0 <24.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^1.0.0",
    "@inquirer/prompts": "^7.0.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@slack/bolt": "^4.1.0",
    "@tanstack/react-query": "^5.90.21",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^13.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "lucide-react": "^0.576.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "semver": "^7.7.4",
    "tailwind-merge": "^3.5.0",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist",
    "templates",
    "examples"
  ]
